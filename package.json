{
  "name": "a11y-node-crawler",
  "version": "2.0.0",
  "description": "Accessibility crawler using Puppeteer + axe-core with WCAG level filtering and CLI support",
  "main": "dist/index.js",
  "bin": {
    "a11y-crawler": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "start": "ts-node cli.ts"
  },
  "dependencies": {
    "axe-core": "^4.12.1",
    "better-sqlite3": "^12.11.1",
    "puppeteer-core": "^22.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "puppeteer",
    "axe-core",
    "crawler"
  ],
  "license": "MIT"
}
